---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/url';
---

<BaseLayout
	title="Fun Stuff"
	description="Interests and experiments that keep my creativity moving. Trade shows, hobbies, and rapid prototyping experiments."
>
	<div class="container">
		<header class="page-header">
			<h1>Fun Stuff</h1>
			<p class="lead">Interests and experiments that keep my creativity moving.</p>
		</header>

		<!-- Links & Media — top, immediately actionable -->
		<section class="links-section" aria-label="Links and media">
			<h2>Links &amp; Media</h2>
			<div class="links-grid">
				<a href="https://github.com/FlamingMachTurtle" class="link-card" target="_blank" rel="noopener">
					<div class="link-icon github" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
					</div>
					<div class="link-body">
						<span class="link-name">GitHub</span>
						<span class="link-desc">Latest published projects and rapid prototyping experiments</span>
					</div>
				</a>
				<a href="https://my-90-day-showcase.vercel.app/" class="link-card" target="_blank" rel="noopener">
					<div class="link-icon showcase" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
					</div>
					<div class="link-body">
						<span class="link-name">90-Day Showcase</span>
						<span class="link-desc">Interactive demos built during the daily development challenge</span>
					</div>
				</a>
				<a href="https://www.linkedin.com/in/eli-goldberger-b3b440212/" class="link-card" target="_blank" rel="noopener">
					<div class="link-icon linkedin" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
					</div>
					<div class="link-body">
						<span class="link-name">LinkedIn</span>
						<span class="link-desc">Professional profile, experience, and connections</span>
					</div>
				</a>
			</div>
		</section>

		<!-- About My Free Time — full-width, scannable -->
		<section class="hobbies-section" aria-label="Hobbies and interests">
			<h2>About My Free Time</h2>
			<p class="hobbies-intro">
				During the semester most of my time goes to classes and side projects, so free time is pretty limited. When I do have it, it tends to fall into a few buckets:
			</p>
			<div class="hobbies-grid">
				<div class="hobby-item">
					<span class="hobby-label">Building &amp; Experimenting</span>
					<span class="hobby-detail">Hacking on random prototype ideas for web apps, trying out new frameworks, or playing with visual experiments.</span>
				</div>
				<div class="hobby-item">
					<span class="hobby-label">Movies &amp; TV</span>
					<span class="hobby-detail">Big fan of comedies and psychological thrillers. Rewatches of <em>Prisoners</em>, <em>The Prestige</em>, and <em>Robots</em> are always in rotation.</span>
				</div>
				<div class="hobby-item">
					<span class="hobby-label">Friends &amp; Family</span>
					<span class="hobby-detail">Theater trips, disc golf, rock climbing on special occasions, and mostly just hanging out with people close to me.</span>
				</div>
			</div>
		</section>

		<!-- Trade Show Photos — full-width at bottom -->
		<section class="gallery-section" aria-label="Trade show photos">
			<h2>Trade Show Photos</h2>
			<p>From B2B buyer-to-buyer shows in Atlanta and Las Vegas with Honey Smitten — enthusiastic buyers, a surprise airport delay, and an incredible KitKat wall.</p>
			<div class="gallery-grid">
				<figure>
					<img src={withBase('/images/b2b-shows/atlanta/atlanta-show.jpg')} alt="Eli Goldberger standing with the Honey Smitten team at a colorful buyer-to-buyer trade show booth in Atlanta." loading="lazy" decoding="async" />
					<figcaption>Booth in Atlanta</figcaption>
				</figure>
				<figure>
					<img src={withBase('/images/b2b-shows/atlanta/airport.jpg')} alt="Crowded airport concourse with travelers waiting under a glitching information screen showing a sad face emoji." loading="lazy" decoding="async" />
					<figcaption>Airport delay on the way home</figcaption>
				</figure>
				<figure>
					<img src={withBase('/images/b2b-shows/vegas/vegas-candy.jpg')} alt="Display shelves filled with rows of international KitKat flavors inside a Las Vegas candy shop." loading="lazy" decoding="async" />
					<figcaption>Vegas KitKat lineup</figcaption>
				</figure>
			</div>
		</section>
	</div>
</BaseLayout>

<style>
	.container {
		max-width: 64rem;
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}
	.page-header {
		margin-bottom: 2.5rem;
	}
	.page-header h1 { margin-bottom: 0.25rem; }
	.lead {
		font-size: 1.1rem;
		color: #64748b;
		margin: 0;
	}

	/* Links section */
	.links-section {
		margin-bottom: 2.5rem;
	}
	.links-section h2 {
		font-size: 1.2rem;
		margin: 0 0 1rem;
	}
	.links-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}
	@media (max-width: 640px) {
		.links-grid { grid-template-columns: 1fr; }
	}

	.link-card {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding: 1rem 1.1rem;
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 0.5rem;
		text-decoration: none;
		color: inherit;
		transition: box-shadow 0.15s, border-color 0.15s;
	}
	.link-card:hover {
		border-color: #94a3b8;
		box-shadow: 0 2px 8px rgba(0,0,0,0.06);
	}

	.link-icon {
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.4rem;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.link-icon.github  { background: #1b1f23; color: #fff; }
	.link-icon.showcase { background: #2563eb; color: #fff; }
	.link-icon.linkedin { background: #0077b5; color: #fff; }

	.link-body {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}
	.link-name {
		font-size: 0.9rem;
		font-weight: 600;
		color: #0f172a;
	}
	.link-desc {
		font-size: 0.8rem;
		color: #64748b;
		line-height: 1.4;
	}

	/* Hobbies section */
	.hobbies-section {
		margin-bottom: 2.5rem;
	}
	.hobbies-section h2 {
		font-size: 1.2rem;
		margin: 0 0 0.65rem;
	}
	.hobbies-intro {
		font-size: 0.95rem;
		color: #334155;
		line-height: 1.6;
		margin: 0 0 1rem;
	}
	.hobbies-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}
	@media (max-width: 640px) {
		.hobbies-grid { grid-template-columns: 1fr; }
	}
	.hobby-item {
		padding: 0.9rem 1rem;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 0.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}
	.hobby-label {
		font-size: 0.85rem;
		font-weight: 600;
		color: #334155;
	}
	.hobby-detail {
		font-size: 0.82rem;
		color: #64748b;
		line-height: 1.5;
	}

	/* Gallery */
	.gallery-section h2 {
		font-size: 1.2rem;
		margin: 0 0 0.3rem;
	}
	.gallery-section > p {
		color: #64748b;
		font-size: 0.9rem;
		margin: 0 0 1rem;
		line-height: 1.5;
	}
	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
		gap: 1rem;
	}
	.gallery-grid figure {
		margin: 0;
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 0.5rem;
		overflow: hidden;
		text-align: center;
	}
	.gallery-grid img {
		width: 100%;
		height: 12rem;
		object-fit: cover;
		display: block;
	}
	.gallery-grid figcaption {
		padding: 0.4rem 0.75rem;
		font-size: 0.82rem;
		color: #64748b;
	}
</style>
