---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroScene from '../../components/HeroScene.astro';
import { withBase } from '../../lib/url';

const hobbies: { label: string; detail: string }[] = [
	{ label: 'Building & Experimenting', detail: 'Hacking on random prototype ideas for web apps, trying out new frameworks, or playing with visual experiments.' },
	{ label: 'Movies & TV',                detail: 'Big fan of comedies and psychological thrillers. Rewatches of <em>Prisoners</em>, <em>The Prestige</em>, and <em>Robots</em> are always in rotation.' },
	{ label: 'Friends & Family',          detail: 'Theater trips, disc golf, rock climbing on special occasions, and mostly just hanging out with people close to me.' },
];

const galleryItems: { src: string; alt: string; cap: string }[] = [
	{ src: '/images/b2b-shows/atlanta/atlanta-show.jpg', alt: 'Eli Goldberger standing with the Honey Smitten team at a colorful buyer-to-buyer trade show booth in Atlanta.', cap: 'Booth in Atlanta' },
	{ src: '/images/b2b-shows/atlanta/airport.jpg',      alt: 'Crowded airport concourse with travelers waiting under a glitching information screen showing a sad face emoji.', cap: 'Airport delay on the way home' },
	{ src: '/images/b2b-shows/vegas/vegas-candy.jpg',    alt: 'Display shelves filled with rows of international KitKat flavors inside a Las Vegas candy shop.', cap: 'Vegas KitKat lineup' },
];
---

<BaseLayout
	title="Fun Stuff"
	description="Interests and experiments that keep my creativity moving. Trade shows, hobbies, and rapid prototyping experiments."
>
	<HeroScene
		eyebrow="Hobbies · Trade shows · Experiments"
		title="Fun Stuff"
		subtitle="Interests and experiments that keep my creativity moving."
		bgImage="/images/b2b-shows/vegas/vegas-candy.jpg"
		bgAlt=""
	/>

	<div class="container">
		<!-- Links & Media — same hairline-separated row pattern as the
		     home page's "Continue" links, but with a small brand-color
		     icon glyph in the leading column. No card chrome. -->
		<section class="links-section" aria-label="Links and media">
			<h2>Links &amp; Media</h2>
			<ul class="links-list">
				<li>
					<a href="https://github.com/FlamingMachTurtle" target="_blank" rel="noopener">
						<span class="link-glyph github" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
						</span>
						<span class="link-name">GitHub</span>
						<span class="link-desc">Latest published projects and rapid prototyping experiments</span>
					</a>
				</li>
				<li>
					<a href="https://my-90-day-showcase.vercel.app/" target="_blank" rel="noopener">
						<span class="link-glyph showcase" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
						</span>
						<span class="link-name">90-Day Showcase</span>
						<span class="link-desc">Interactive demos built during the daily development challenge</span>
					</a>
				</li>
				<li>
					<a href="https://www.linkedin.com/in/eli-goldberger-b3b440212/" target="_blank" rel="noopener">
						<span class="link-glyph linkedin" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</span>
						<span class="link-name">LinkedIn</span>
						<span class="link-desc">Professional profile, experience, and connections</span>
					</a>
				</li>
			</ul>
		</section>

		<!-- About My Free Time — same definition-list pattern as Skills
		     on home. No bordered cards, no border-left rule. -->
		<section class="hobbies-section" aria-label="Hobbies and interests">
			<h2>About My Free Time</h2>
			<p class="hobbies-intro">
				During the semester most of my time goes to classes and side projects, so free time is pretty limited. When I do have it, it tends to fall into a few buckets:
			</p>
			<dl class="hobbies-list">
				{hobbies.map(({ label, detail }) => (
					<div class="hobbies-row">
						<dt>{label}</dt>
						<dd set:html={detail}></dd>
					</div>
				))}
			</dl>
		</section>

		<!-- Trade Show Photos — minimal figures matching the projects-page
		     gallery pattern. No bordered backgrounds; just hairline-bordered
		     images with captions below. -->
		<section class="gallery-section" aria-label="Trade show photos">
			<h2>Trade Show Photos</h2>
			<p class="gallery-intro">From B2B buyer-to-buyer shows in Atlanta and Las Vegas with Honey Smitten — enthusiastic buyers, a surprise airport delay, and an incredible KitKat wall.</p>
			<div class="gallery-grid">
				{galleryItems.map(({ src, alt, cap }) => (
					<figure>
						<img src={withBase(src)} alt={alt} loading="lazy" decoding="async" />
						<figcaption>{cap}</figcaption>
					</figure>
				))}
			</div>
		</section>
	</div>
</BaseLayout>

<style>
	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--space-lg) var(--space-xl);
	}

	.links-section,
	.hobbies-section,
	.gallery-section {
		margin-bottom: var(--space-3xl);
	}
	.links-section h2,
	.hobbies-section h2,
	.gallery-section h2 {
		font-size: var(--fs-2xl);
		font-weight: 600;
		line-height: var(--lh-tight);
		letter-spacing: -0.02em;
		margin: 0 0 var(--space-lg);
	}

	/* ===== Links =====
	   3 hairline-separated rows. Each row: small inline brand-color
	   glyph + name + description. Whole row is the link target. */
	.links-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.links-list li {
		border-top: 1px solid var(--color-border);
	}
	.links-list li:last-child { border-bottom: 1px solid var(--color-border); }
	.links-list a {
		display: grid;
		grid-template-columns: 1.5rem auto 1fr;
		column-gap: var(--space-md);
		align-items: center;
		padding: var(--space-md) 0;
		color: var(--color-text);
		text-decoration: none;
		transition: color 0.18s ease;
	}
	.links-list a:hover { color: var(--color-accent); }

	.link-glyph {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
	}
	/* Brand-correct icon colors stay — confirmed in the audit as one
	   place brand identity beats palette uniformity. Glyphs sit on
	   transparent ground (no colored square background). */
	.link-glyph.github   { color: var(--color-text); }
	.link-glyph.showcase { color: var(--color-accent); }
	.link-glyph.linkedin { color: #0077b5; }

	.link-name {
		font-size: var(--fs-md);
		font-weight: 600;
		letter-spacing: -0.01em;
	}
	.link-desc {
		font-size: var(--fs-sm);
		line-height: var(--lh-snug);
		color: var(--color-text-muted);
	}

	@media (max-width: 640px) {
		.links-list a {
			grid-template-columns: 1.5rem 1fr;
			row-gap: var(--space-2xs);
		}
		.link-desc { grid-column: 2 / -1; }
	}

	/* ===== Hobbies =====
	   Definition list. Same pattern as the Skills section on home,
	   minus the mono treatment (these are sentences, not tags). */
	.hobbies-intro {
		font-size: var(--fs-sm);
		color: var(--color-text-muted);
		line-height: var(--lh-base);
		margin: 0 0 var(--space-xl);
		max-width: 56rem;
	}
	.hobbies-list {
		margin: 0;
		padding: 0;
	}
	.hobbies-row {
		display: grid;
		grid-template-columns: 14rem 1fr;
		gap: var(--space-xl);
		padding: var(--space-md) 0;
		border-top: 1px solid var(--color-border);
	}
	.hobbies-row:last-child { border-bottom: 1px solid var(--color-border); }
	.hobbies-row dt {
		margin: 0;
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text);
		padding-top: 2px;
	}
	.hobbies-row dd {
		margin: 0;
		font-size: var(--fs-sm);
		line-height: var(--lh-base);
		color: var(--color-text-muted);
	}
	.hobbies-row dd :global(em) { font-style: italic; color: var(--color-text); }
	@media (max-width: 640px) {
		.hobbies-row {
			grid-template-columns: 1fr;
			gap: var(--space-2xs);
		}
	}

	/* ===== Gallery =====
	   Same minimal pattern as projects: hairline-bordered images,
	   no figure background, no card chrome. Caption sits below in
	   plain text. */
	.gallery-intro {
		color: var(--color-text-muted);
		font-size: var(--fs-sm);
		margin: 0 0 var(--space-xl);
		line-height: var(--lh-snug);
		max-width: 56rem;
	}
	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
		gap: var(--space-md);
	}
	.gallery-grid figure {
		margin: 0;
	}
	.gallery-grid img {
		width: 100%;
		height: 12rem;
		object-fit: cover;
		display: block;
		border-radius: var(--radius-sm);
		border: 1px solid var(--color-border);
	}
	.gallery-grid figcaption {
		margin-top: var(--space-2xs);
		font-size: var(--fs-xs);
		color: var(--color-text-muted);
	}
</style>
