---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroScene from '../components/HeroScene.astro';
import TechMarquee from '../components/TechMarquee.astro';
import TechBadge from '../components/TechBadge.astro';
import StatStrip from '../components/StatStrip.astro';
import ScrollReveal from '../components/react/ScrollReveal.tsx';
import { withBase } from '../lib/url';

const headshot = withBase('/images/headshot.jpg');

// Skills, modeled as definition-list rows. Each row renders as
//   [CATEGORY in small-caps left column] | [items separated by · in mono right column]
// The previous implementation was a 2x2 grid of bordered "skill-group"
// cards (a Tailwind-UI tag-set tell — see redesign/audit/ai-tells.md).
// `mode` controls how each row renders:
//   - 'badges': icon+label pills via <TechBadge /> (real brand SVGs from
//     `simple-icons`, monochrome by default, brand-color on hover)
//   - 'mono':   small-caps mono dot-separated list (the editorial baseline
//     for non-iconic skills like "Inquiry-based coaching")
const skills: { label: string; items: string[]; mode: 'badges' | 'mono' }[] = [
	{ label: 'Languages',                mode: 'badges', items: ['Python','Java','JavaScript','TypeScript','SQL','Swift','HTML / CSS'] },
	{ label: 'Frameworks & Tools',       mode: 'badges', items: ['React','Node.js','Astro','SwiftUI','Vite','Supabase','Vercel','GSAP','Framer Motion','Git','GitHub Actions','eBay Trading API','QuickBooks Online','Google Sheets'] },
	{ label: 'Professional Competencies',mode: 'mono',   items: ['Client communication','Requirements gathering','Rapid prototyping','QA & release coordination','1:1 & small-group instruction','Inquiry-based coaching','Operations & reporting','Documentation & handoffs'] },
	{ label: 'Human Languages',          mode: 'mono',   items: ['English (native)','Japanese (intermediate)','Hebrew (basic)'] },
];

const exploreLinks: { href: string; label: string; desc: string }[] = [
	{ href: withBase('/projects/'), label: 'Projects & Experiences', desc: '8 entries spanning CS, interdisciplinary, outside-CS, and the CISC480 capstone — with SOAR and failure stories' },
	{ href: withBase('/resume/'),   label: 'Resume',                 desc: 'Experience, education, and skills — viewable inline or downloadable as PDF' },
	{ href: withBase('/fun/'),      label: 'Fun Stuff',              desc: 'Hobbies, trade-show photos, and side interests' },
];
---

<BaseLayout
	title="Home"
	description="CISC480 Senior Capstone individual portfolio. Computer Science major (Mathematics & Game Design minors) at the University of St. Thomas. Practical automation, rapid prototyping, and tools that help small businesses and underserved users."
>
	<HeroScene
		tall
		eyebrow="CISC480 · Senior Capstone · Section 02 · Spring 2026"
		title="Eli Goldberger"
		subtitle="B.S. Computer Science (May 2026) · Minors in Mathematics & Game Design · University of St. Thomas. Practical, ethical automation for small businesses and underserved users."
	/>

	<div class="container">
		<header class="hero">
			<div class="headshot-frame">
				<img src={headshot} alt="Headshot of Eli Goldberger" width="256" height="256" loading="eager" />
			</div>
			<div class="hero-text">
				<p class="lead">
					I ship working tools fast — especially for small businesses and people who don't usually get custom
					software built for them.
				</p>
				<p class="contact-line">
					<a href="mailto:eligoldberger5@gmail.com">eligoldberger5@gmail.com</a>
					<span aria-hidden="true">·</span>
					<a href="https://www.linkedin.com/in/eli-goldberger-b3b440212/" target="_blank" rel="noopener">LinkedIn</a>
					<span aria-hidden="true">·</span>
					<a href="https://github.com/FlamingMachTurtle" target="_blank" rel="noopener">GitHub</a>
				</p>
				<p class="course-context">
					Individual portfolio + signature work reflection. The full reflection lives in this repo's
					<a href="https://github.com/FlamingMachTurtle/cisc480-portfolio#holistic-signature-work-reflection" target="_blank" rel="noopener">README</a>.
				</p>
			</div>
		</header>

		<!-- ========== ABOUT ==========
		     V6.1 tone-down: dropped the pull quote, dropped the
		     CS↔LA paired/parallel split, and flattened to a single
		     hairline-separated list of independent factual bullets.
		     Self-claim adjectives stripped from each line (no "tight
		     deadlines", no "rigor", no "comfort with ambiguity"); the
		     closing line is descriptive context, not a value
		     proposition. See redesign/audit/about-and-stats-v6.md
		     for the reasoning behind the revision.

		     V6.2 fix (May 20): restored a short editorial lead at the
		     top of the section that explicitly answers the rubric's
		     "Why should we hire you?" using the ACM Interview Speak
		     unique-combination pattern (CS skills + liberal-arts
		     strengths). This is the framing the PDF rubric scores
		     under "Interview-Ready Narratives", and the V6.1
		     bullets-only treatment left it implicit. The bullets
		     below remain unchanged — they are the evidence, the new
		     lead is the claim. -->
		<ScrollReveal client:load>
		<section class="about-section" id="about" aria-labelledby="about-heading">
			<h2 id="about-heading">About</h2>

			<p class="about-claim">
				<span class="about-claim__q">Why should we hire you?</span>
				I'm not only a computer-science major who ships production automation
				against real APIs (Python, React + Supabase, SwiftUI, image pipelines) —
				I'm also a small-business operator (Honey Smitten, my own LLC Big Chuck
				Data), an AVID inquiry-based tutor, a Math minor, and someone who has
				worked across English, intermediate Japanese, and basic Hebrew. That
				combination is why I'm comfortable in the room where the requirements
				aren't written down yet — small-business owners, classrooms, and
				municipal staff — and why my code carries the ethical guardrails
				(deactivate-by-default, audit logs, dry-run modes, rate-limit-aware
				queues) those users actually need.
			</p>

			<ul class="about-list">
				<li>Builds and ships tools to paying clients.</li>
				<li>Python automation against real APIs &mdash; rate limits, auth, idempotency.</li>
				<li>SwiftUI / iOS native; React, Node, Astro on the web.</li>
				<li>Image pipelines, scheduled services, data workflows.</li>
				<li>Operations and client work for my LLC and Honey Smitten.</li>
				<li>AVID 1:1 tutoring; middle-schoolers across multiple sites.</li>
				<li>Math minor; intermediate Japanese, basic Hebrew.</li>
			</ul>

			<p class="about-summary">
				Most of my work so far has been for small-business owners, AVID classrooms, and
				a sustainability dashboard pilot.
			</p>
		</section>
		</ScrollReveal>

		<!-- ========== BY THE NUMBERS ==========
		     V6 add: a small stat strip with four real metrics that
		     count up from 0 when scrolled into view. SSR-rendered
		     final values; no animation under prefers-reduced-motion. -->
		<ScrollReveal client:load>
		<StatStrip
			eyebrow="By the numbers"
			stats={[
				{ value: 22, label: 'Widgets', sublabel: 'GreenStep dashboard' },
				{ value: 100, suffix: '%', label: 'Success rate', sublabel: 'eBay pipeline, post-redesign' },
				{ value: 8, label: 'Projects shipped', sublabel: 'On this site' },
				{ value: 21, label: 'Months running', sublabel: 'Big Chuck Data LLC' },
			]}
		/>
		</ScrollReveal>

		<!-- ========== SKILLS ==========
		     v2: 4-up bordered card grid → definition-list (label | mono
		     items separated by ·). Hairline rule between rows. -->
		<ScrollReveal client:load>
		<section class="skills-section" id="skills" aria-labelledby="skills-heading">
			<h2 id="skills-heading">Skills</h2>
			<p class="skills-intro">Pulled from coursework, paid work, and service learning.</p>

			<dl class="skills-list">
				{skills.map(({ label, items, mode }) => (
					<div class="skills-row">
						<dt>{label}</dt>
						{mode === 'badges' ? (
							<dd class="skills-badges">
								{items.map((it) => <TechBadge name={it} />)}
							</dd>
						) : (
							<dd class="mono">{items.join('  ·  ')}</dd>
						)}
					</div>
				))}
			</dl>
		</section>
		</ScrollReveal>

		<!-- ========== TECH STACK MARQUEE ==========
		     Continuous horizontal lockup of the tools in active rotation.
		     Pauses on hover. CSS-only — zero client JS. -->
		<ScrollReveal client:load>
			<TechMarquee />
		</ScrollReveal>

		<!-- ========== GOALS ========== -->
		<ScrollReveal client:load>
		<section class="goals-section" aria-labelledby="goals-heading">
			<h2 id="goals-heading">Goals</h2>
			<ul>
				<li>Keep sharpening rapid-prototyping under short deadlines.</li>
				<li>Grow <strong>Big Chuck Data LLC</strong> into a small-business consultancy that doesn't overcharge or over-automate.</li>
				<li>Move toward human-centered software in spaces where care matters.</li>
				<li>Keep service-learning alongside the technical work — the two sharpen each other.</li>
			</ul>
		</section>
		</ScrollReveal>

		<!-- ========== EXPLORE ==========
		     v2: 3-column CTA tile grid → 3 typographic rows, hairline-
		     separated, with → arrow leading the title. -->
		<ScrollReveal client:load>
		<nav class="explore" aria-label="Explore this site">
			<span class="explore-kicker">Continue</span>
			<ul>
				{exploreLinks.map(({ href, label, desc }) => (
					<li>
						<a href={href}>
							<span class="explore-arrow" aria-hidden="true">→</span>
							<span class="explore-label">{label}</span>
							<span class="explore-desc">{desc}</span>
						</a>
					</li>
				))}
			</ul>
		</nav>
		</ScrollReveal>

		<!-- ========== CREDITS ROW ==========
		     v2: 3-column stat row → film-credits-style line block.
		     Mono label hugging left, content in body type, no vertical
		     dividers. -->
		<ScrollReveal client:load>
		<dl class="credits">
			<div class="credits-row">
				<dt>Latest</dt>
				<dd>eBay pipeline — 100% production success rate</dd>
			</div>
			<div class="credits-row">
				<dt>Focus</dt>
				<dd>Practical, ethical automation for small businesses &amp; underserved users</dd>
			</div>
			<div class="credits-row">
				<dt>Available</dt>
				<dd>Open to consulting &amp; collaboration — <a href="mailto:eligoldberger5@gmail.com">get in touch</a></dd>
			</div>
		</dl>
		</ScrollReveal>
	</div>
</BaseLayout>

<style>
	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--space-lg) var(--space-xl);
	}

	.hero {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xl);
		align-items: center;
		margin-bottom: var(--space-3xl);
	}
	.headshot-frame { flex-shrink: 0; }
	.headshot-frame img {
		width: 9rem;
		height: 9rem;
		border-radius: 50%;
		display: block;
		object-fit: cover;
		box-shadow: 0 0 0 3px var(--color-border), 0 0 0 5px var(--color-bg), var(--shadow-2);
	}
	.hero-text { flex: 1; min-width: 0; }
	.lead {
		font-size: var(--fs-md);
		line-height: var(--lh-snug);
		margin: 0 0 var(--space-sm);
		color: var(--color-text);
	}
	.contact-line {
		margin: 0 0 var(--space-xs);
		font-size: var(--fs-sm);
		color: var(--color-text-muted);
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
		align-items: baseline;
	}
	.course-context {
		margin: 0;
		font-size: var(--fs-xs);
		color: var(--color-text-subtle);
		line-height: var(--lh-snug);
	}

	/* ===== Section heads (shared across home) =====
	   Single typographic moment — no kicker pill, no number prefix. */
	.about-section h2,
	.skills-section h2,
	.goals-section h2 {
		margin: 0 0 var(--space-2xs);
		font-size: var(--fs-2xl);
		font-weight: 600;
		line-height: var(--lh-tight);
		letter-spacing: -0.02em;
	}

	/* ===== About =====
	   Heading + question lead + two-column comparison + summary.
	   No card chrome anywhere. The vertical hairline does the
	   visual separation that the borders used to do. */
	.about-section { margin-bottom: var(--space-3xl); }

	/* ----- "Why should we hire you?" claim -----
	   Single editorial paragraph that opens the About section with
	   the ACM unique-combination framing the rubric scores under.
	   No card chrome — just an emphasized italic question lead-in
	   followed by body prose. See redesign/audit/about-and-stats-v6.md. */
	.about-claim {
		margin: var(--space-md) 0 var(--space-xl);
		max-width: 56rem;
		font-size: var(--fs-md);
		line-height: var(--lh-snug);
		color: var(--color-text);
	}
	.about-claim__q {
		display: block;
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text-subtle);
		margin-bottom: var(--space-2xs);
	}

	/* ----- Flat skills list -----
	   One bullet per row, hairline rule between rows. No
	   categorization, no comparison, no inline glyphs. Each line
	   is a self-contained factual descriptor. */
	.about-list {
		list-style: none;
		margin: 0;
		padding: 0;
		max-width: 56rem;
	}
	.about-list li {
		font-size: var(--fs-sm);
		line-height: var(--lh-snug);
		color: var(--color-text);
		padding: var(--space-sm) 0;
		border-top: 1px solid var(--color-border);
	}
	.about-list li:last-child { border-bottom: 1px solid var(--color-border); }

	/* ----- Closing line -----
	   Plain paragraph; no kicker, no drop cap, no special
	   typography — it's context, not a value proposition. */
	.about-summary {
		margin: var(--space-xl) 0 0;
		max-width: 56rem;
		font-size: var(--fs-sm);
		line-height: var(--lh-base);
		color: var(--color-text-muted);
	}

	/* ===== Skills =====
	   Definition-list. Each row = small-caps label hugging left
	   in a fixed-width column + mono inline items separated by
	   middle-dots. Hairline rule between rows. No card chrome. */
	.skills-section { margin-bottom: var(--space-3xl); }
	.skills-intro {
		font-size: var(--fs-sm);
		color: var(--color-text-muted);
		margin: 0 0 var(--space-xl);
		max-width: 48rem;
	}
	.skills-list {
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}
	.skills-row {
		display: grid;
		grid-template-columns: 12rem 1fr;
		gap: var(--space-xl);
		padding: var(--space-md) 0;
		border-top: 1px solid var(--color-border);
	}
	.skills-row:last-child { border-bottom: 1px solid var(--color-border); }
	.skills-row dt {
		margin: 0;
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text);
		padding-top: 2px;
	}
	.skills-row dd {
		margin: 0;
		font-size: var(--fs-sm);
		line-height: var(--lh-base);
		color: var(--color-text-muted);
		font-feature-settings: "tnum" on, "ss01" on, "ss03" on;
	}
	.skills-row dd.skills-badges {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2xs);
		font-feature-settings: normal;
	}
	@media (max-width: 640px) {
		.skills-row {
			grid-template-columns: 1fr;
			gap: var(--space-2xs);
		}
	}

	/* ===== Goals ===== */
	.goals-section { margin-bottom: var(--space-3xl); }
	.goals-section ul {
		margin: var(--space-md) 0 0;
		padding-left: var(--space-md);
		line-height: var(--lh-base);
		list-style: none;
	}
	.goals-section li {
		margin-bottom: var(--space-xs);
		color: var(--color-text);
		padding-left: 0.9rem;
		position: relative;
	}
	.goals-section li::before {
		content: '';
		position: absolute;
		left: -0.9rem;
		top: 0.6em;
		width: 0.5rem;
		height: 1px;
		background: var(--color-border-strong);
	}

	/* ===== Explore =====
	   3 hairline-separated rows. Each row: arrow + label + dimmer
	   description. Whole row is the link target. */
	.explore {
		margin-bottom: var(--space-3xl);
	}
	.explore-kicker {
		display: block;
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text-subtle);
		margin-bottom: var(--space-xs);
	}
	.explore ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.explore li {
		border-top: 1px solid var(--color-border);
	}
	.explore li:last-child { border-bottom: 1px solid var(--color-border); }
	.explore a {
		display: grid;
		grid-template-columns: 1.5rem auto 1fr;
		column-gap: var(--space-sm);
		align-items: baseline;
		padding: var(--space-md) 0;
		color: var(--color-text);
		text-decoration: none;
		transition: color 0.18s ease;
	}
	.explore a:hover { color: var(--color-accent); }
	.explore a:hover .explore-arrow { transform: translateX(2px); }
	.explore-arrow {
		font-family: var(--font-mono);
		color: var(--color-text-subtle);
		transition: transform 0.18s ease;
	}
	.explore a:hover .explore-arrow { color: var(--color-accent); }
	.explore-label {
		font-size: var(--fs-md);
		font-weight: 600;
		letter-spacing: -0.01em;
	}
	.explore-desc {
		font-size: var(--fs-sm);
		line-height: var(--lh-snug);
		color: var(--color-text-muted);
	}
	@media (max-width: 640px) {
		.explore a {
			grid-template-columns: 1.5rem 1fr;
		}
		.explore-desc {
			grid-column: 2 / -1;
			margin-top: var(--space-2xs);
		}
	}

	/* ===== Credits =====
	   Film-credits-style line block. Mono small-caps label in fixed
	   left column, prose body in normal sans on the right.
	   Replaces the 3-column stat row with vertical dividers. */
	.credits {
		margin: 0;
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}
	.credits-row {
		display: grid;
		grid-template-columns: 8rem 1fr;
		column-gap: var(--space-lg);
		padding: var(--space-2xs) 0;
	}
	.credits-row dt {
		margin: 0;
		font-family: var(--font-mono);
		font-size: var(--fs-2xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-text-subtle);
		padding-top: 2px;
	}
	.credits-row dd {
		margin: 0;
		font-size: var(--fs-sm);
		line-height: var(--lh-base);
		color: var(--color-text);
	}
	.credits-row dd a {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 2px;
		text-decoration-color: var(--color-border-strong);
	}
	.credits-row dd a:hover {
		color: var(--color-accent);
		text-decoration-color: currentColor;
	}
	@media (max-width: 640px) {
		.credits-row {
			grid-template-columns: 1fr;
			gap: var(--space-2xs);
			padding: var(--space-xs) 0;
		}
	}
</style>
