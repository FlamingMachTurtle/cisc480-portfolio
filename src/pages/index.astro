---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroScene from '../components/HeroScene.astro';
import { withBase } from '../lib/url';

const headshot = withBase('/images/headshot.jpg');
---

<BaseLayout
	title="Home"
	description="CISC480 Senior Capstone individual portfolio. Computer Science major (Mathematics & Game Design minors) at the University of St. Thomas. Practical automation, rapid prototyping, and tools that help small businesses and underserved users."
>
	<HeroScene
		tall
		eyebrow="CISC480 · Senior Capstone · Section 02 · Spring 2026"
		title="Eli Goldberger"
		subtitle="B.S. Computer Science (May 2026) · Minors in Mathematics & Game Design · University of St. Thomas. Practical, ethical automation for small businesses and underserved users."
	/>

	<div class="container">
		<header class="hero">
			<div class="headshot-frame">
				<img src={headshot} alt="Headshot of Eli Goldberger" width="256" height="256" loading="eager" />
			</div>
			<div class="hero-text">
				<p class="lead">
					I turn ideas into working tools fast, especially for small businesses and people who don't usually get
					custom software built for them. My longer-term goal is to contribute to medical and mental-health tech.
				</p>
				<p class="contact-line">
					<a href="mailto:eligoldberger5@gmail.com">eligoldberger5@gmail.com</a>
					· <a href="https://www.linkedin.com/in/eli-goldberger-b3b440212/" target="_blank" rel="noopener">LinkedIn</a>
					· <a href="https://github.com/FlamingMachTurtle" target="_blank" rel="noopener">GitHub</a>
				</p>
				<p class="course-context">
					Individual portfolio + signature work reflection. The full reflection lives in this repo's
					<a href="https://github.com/FlamingMachTurtle/cisc480-portfolio#holistic-signature-work-reflection" target="_blank" rel="noopener">README</a>.
				</p>
			</div>
		</header>

		<!-- ========== ABOUT ME (ACM "unique combination") ========== -->
		<section class="about-section" id="about" aria-labelledby="about-heading">
			<h2 id="about-heading">About Me</h2>
			<p class="about-question">
				<strong>Why should you hire me?</strong> Because I bring a unique combination of CS and liberal-arts strengths
				that's pretty hard to find together in one person.
			</p>
			<div class="combination">
				<div class="combo-card">
					<span class="combo-label">CS strengths</span>
					<ul>
						<li>Rapid Python automation against real REST/API constraints (rate limits, auth, idempotency).</li>
						<li>End-to-end shipping of production tools under tight client deadlines.</li>
						<li>SwiftUI / iOS for native interfaces; React, Node, and Astro on the web.</li>
						<li>Image processing pipelines, scheduled services, and small-business data workflows.</li>
					</ul>
				</div>
				<div class="combo-card">
					<span class="combo-label">Liberal-arts strengths</span>
					<ul>
						<li>1:1 and small-group instruction through AVID — I can debug an API and then explain it to a 7th-grader.</li>
						<li>Intermediate Japanese and basic Hebrew — comfort sitting with ambiguity and other ways of thinking.</li>
						<li>Math minor rigor: I can reason about edge cases, model failure modes, and check my own work.</li>
						<li>Operations &amp; client communication from running my own LLC and supporting Honey Smitten through trade shows, QuickBooks, and reporting.</li>
					</ul>
				</div>
			</div>
			<p class="about-summary">
				<strong>Net-net:</strong> I'm a developer who can talk to non-technical clients without losing them,
				ship reliable automation that respects real-world constraints, and treat the people I build for —
				whether they're store owners, middle-school students, or future patients — with the kind of care
				the University of St. Thomas tradition expects.
			</p>
		</section>

		<!-- ========== SKILLS ========== -->
		<section class="skills-section" id="skills" aria-labelledby="skills-heading">
			<h2 id="skills-heading">Skills</h2>
			<p class="skills-intro">Salient technical skills and professional competencies — pulled from coursework, paid work, and service learning.</p>
			<div class="skills-grid">
				<div class="skill-group">
					<h3>Languages</h3>
					<ul class="pill-list">
						<li>Python</li><li>Java</li><li>JavaScript</li><li>TypeScript</li>
						<li>SQL</li><li>Swift</li><li>HTML / CSS</li>
					</ul>
				</div>
				<div class="skill-group">
					<h3>Frameworks &amp; Tools</h3>
					<ul class="pill-list">
						<li>React</li><li>Node.js</li><li>Astro</li><li>SwiftUI</li>
						<li>REST APIs</li><li>eBay Trading API</li><li>QuickBooks Online</li>
						<li>Google Sheets automation</li><li>Power BI / DAX</li><li>Git / GitHub Actions</li>
					</ul>
				</div>
				<div class="skill-group">
					<h3>Professional Competencies</h3>
					<ul class="pill-list">
						<li>Client communication</li><li>Requirements gathering</li>
						<li>Rapid prototyping</li><li>QA &amp; release coordination</li>
						<li>1:1 &amp; small-group instruction</li><li>Inquiry-based coaching</li>
						<li>Operations &amp; reporting</li><li>Documentation &amp; handoffs</li>
					</ul>
				</div>
				<div class="skill-group">
					<h3>Human Languages</h3>
					<ul class="pill-list">
						<li>English (native)</li><li>Japanese (intermediate)</li><li>Hebrew (basic)</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- ========== GOALS ========== -->
		<section class="goals-section" aria-labelledby="goals-heading">
			<h2 id="goals-heading">Goals</h2>
			<ul>
				<li>Keep sharpening rapid-prototyping skills so I can ship useful tools on short deadlines.</li>
				<li>Grow <strong>Big Chuck Data LLC</strong> into a sustainable consultancy that supports small-business clients end to end without overcharging or over-automating.</li>
				<li>Move toward contributing to medical and mental-health technology — the spaces where careful, human-centered software matters most.</li>
				<li>Keep doing service-learning work alongside the technical work, because the two sharpen each other.</li>
			</ul>
		</section>

		<!-- ========== EXPLORE ========== -->
		<nav class="explore" aria-label="Explore this site">
			<a href={withBase('/projects/')} class="explore-item">
				<span class="explore-label">Projects &amp; Experiences</span>
				<span class="explore-desc">8 entries spanning CS, interdisciplinary, outside-CS, and the CISC480 capstone — with SOAR and failure stories</span>
			</a>
			<a href={withBase('/resume/')} class="explore-item">
				<span class="explore-label">Resume</span>
				<span class="explore-desc">Experience, education, and skills — viewable inline or downloadable as PDF</span>
			</a>
			<a href={withBase('/fun/')} class="explore-item">
				<span class="explore-label">Fun Stuff</span>
				<span class="explore-desc">Hobbies, trade-show photos, and side interests</span>
			</a>
		</nav>

		<!-- ========== STAT ROW ========== -->
		<div class="stat-row" role="list">
			<div class="stat" role="listitem">
				<span class="stat-label">Latest Work</span>
				<span class="stat-value">eBay pipeline — 100% production success rate</span>
			</div>
			<div class="stat-divider" aria-hidden="true"></div>
			<div class="stat" role="listitem">
				<span class="stat-label">Focus</span>
				<span class="stat-value">Practical, ethical automation for small businesses &amp; underserved users</span>
			</div>
			<div class="stat-divider" aria-hidden="true"></div>
			<div class="stat" role="listitem">
				<span class="stat-label">Availability</span>
				<span class="stat-value">Open to consulting &amp; collaboration — <a href="mailto:eligoldberger5@gmail.com">get in touch</a></span>
			</div>
		</div>
	</div>
</BaseLayout>

<style>
	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--space-lg) var(--space-xl);
	}

	/* The pink .capstone-banner is GONE. Course-context lives in the
	   HeroScene eyebrow above and the .course-context line below. */

	.hero {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xl);
		align-items: center;
		margin-bottom: var(--space-2xl);
	}

	.headshot-frame {
		flex-shrink: 0;
	}
	.headshot-frame img {
		width: 9rem;
		height: 9rem;
		border-radius: 50%;
		display: block;
		object-fit: cover;
		box-shadow: 0 0 0 3px var(--color-border), 0 0 0 5px var(--color-bg), var(--shadow-2);
	}

	.hero-text {
		flex: 1;
		min-width: 0;
	}
	.lead {
		font-size: var(--fs-md);
		line-height: var(--lh-snug);
		margin: 0 0 var(--space-sm);
		color: var(--color-text);
	}
	.contact-line {
		margin: 0 0 var(--space-xs);
		font-size: var(--fs-sm);
		color: var(--color-text-muted);
	}
	.course-context {
		margin: 0;
		font-size: var(--fs-xs);
		color: var(--color-text-subtle);
		line-height: var(--lh-snug);
	}

	/* About Me */
	.about-section {
		margin-bottom: var(--space-2xl);
	}
	.about-section h2 {
		margin: 0 0 var(--space-xs);
		font-size: var(--fs-xl);
		line-height: var(--lh-tight);
	}
	.about-question {
		font-size: var(--fs-base);
		line-height: var(--lh-snug);
		margin: 0 0 var(--space-md);
		color: var(--color-text-muted);
	}
	.about-question strong { color: var(--color-text); }

	.combination {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-md);
	}
	@media (max-width: 640px) {
		.combination { grid-template-columns: 1fr; }
	}
	.combo-card {
		padding: var(--space-md) var(--space-lg);
		background: var(--color-surface);
		border-radius: var(--radius-md);
		border-left: 3px solid var(--color-border-strong);
	}
	.combo-label {
		display: block;
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text-muted);
		margin-bottom: var(--space-xs);
	}
	.combo-card ul {
		margin: 0;
		padding-left: 1.1rem;
		font-size: var(--fs-sm);
		line-height: var(--lh-snug);
		color: var(--color-text);
	}
	.combo-card li { margin-bottom: var(--space-2xs); }
	.combo-card li:last-child { margin-bottom: 0; }
	.about-summary {
		margin: var(--space-md) 0 0;
		font-size: var(--fs-sm);
		line-height: var(--lh-base);
		color: var(--color-text-muted);
	}
	.about-summary strong { color: var(--color-text); }

	/* Skills */
	.skills-section {
		margin-bottom: var(--space-2xl);
	}
	.skills-section h2 {
		margin: 0 0 var(--space-xs);
		font-size: var(--fs-xl);
		line-height: var(--lh-tight);
	}
	.skills-intro {
		font-size: var(--fs-sm);
		color: var(--color-text-muted);
		margin: 0 0 var(--space-md);
	}
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-md);
	}
	@media (max-width: 640px) {
		.skills-grid { grid-template-columns: 1fr; }
	}
	.skill-group {
		padding: var(--space-md) var(--space-lg);
		background: var(--color-surface-raised);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
	}
	.skill-group h3 {
		margin: 0 0 var(--space-xs);
		font-size: var(--fs-2xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text);
	}
	.pill-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2xs);
	}
	.pill-list li {
		font-size: var(--fs-xs);
		padding: 0.2rem 0.6rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	/* Goals */
	.goals-section {
		margin-bottom: var(--space-2xl);
	}
	.goals-section h2 {
		margin: 0 0 var(--space-xs);
		font-size: var(--fs-xl);
		line-height: var(--lh-tight);
	}
	.goals-section ul {
		margin: 0;
		padding-left: var(--space-lg);
		line-height: var(--lh-base);
	}
	.goals-section li {
		margin-bottom: var(--space-2xs);
		color: var(--color-text);
	}

	/* Explore */
	.explore {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: var(--color-border);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
		margin-bottom: var(--space-2xl);
	}
	.explore-item {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
		padding: var(--space-md) var(--space-lg);
		background: var(--color-surface);
		text-decoration: none;
		transition: background 0.18s ease;
	}
	.explore-item:hover {
		background: var(--color-surface-raised);
	}
	.explore-label {
		font-size: var(--fs-sm);
		font-weight: 700;
		color: var(--color-text);
	}
	.explore-desc {
		font-size: var(--fs-xs);
		line-height: var(--lh-snug);
		color: var(--color-text-muted);
	}
	@media (max-width: 640px) {
		.explore { grid-template-columns: 1fr; }
	}

	/* Stat row */
	.stat-row {
		display: flex;
		align-items: stretch;
		gap: 0;
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}
	.stat {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
		padding: 0 var(--space-xl) 0 0;
	}
	.stat:last-of-type { padding-right: 0; }
	.stat-label {
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text-subtle);
	}
	.stat-value {
		font-size: var(--fs-sm);
		color: var(--color-text);
		line-height: var(--lh-snug);
	}
	.stat-value a {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.stat-value a:hover { color: var(--color-accent); }
	.stat-divider {
		width: 1px;
		background: var(--color-border);
		margin: 0 var(--space-xl) 0 0;
		flex-shrink: 0;
	}
	@media (max-width: 640px) {
		.stat-row {
			flex-direction: column;
			gap: var(--space-md);
		}
		.stat { padding: 0; }
		.stat-divider { display: none; }
	}
</style>
