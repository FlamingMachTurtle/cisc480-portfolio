---
import { fade } from 'astro:transitions';
import { withBase } from '../lib/url';

/**
 * HeroScene — the cinematic dark band that sits above the body of
 * each major page. Designed to be the "deeper into the scene"
 * surface: it carries transition:name="hero-scene" so the browser
 * morphs the band across page navigations (set up via <ClientRouter />
 * in BaseLayout). The bg image gets its own transition:name so the
 * image content morphs alongside the container.
 *
 * See redesign/design-spec.md §3.3 and
 * redesign/animation-options.md §"Verified API surface (Astro 6.3.1)".
 */
interface Props {
	title: string;
	eyebrow?: string;
	subtitle?: string;
	/** Path under /public, e.g. '/images/greenstep/...'. Optional. */
	bgImage?: string;
	/** Override the default 480px height. Useful for the home page. */
	tall?: boolean;
	/** Alt text for the bg image. Empty by default (decorative). */
	bgAlt?: string;
}

const {
	title,
	eyebrow,
	subtitle,
	bgImage,
	tall = false,
	bgAlt = '',
} = Astro.props;

const bgSrc = bgImage ? withBase(bgImage) : undefined;
---

<section class:list={['hero-scene', { 'hero-scene--tall': tall, 'hero-scene--imageless': !bgSrc }]} transition:name="hero-scene">
	{bgSrc && (
		<img
			src={bgSrc}
			alt={bgAlt}
			class="hero-scene__bg"
			loading="eager"
			decoding="async"
			aria-hidden={bgAlt === '' ? 'true' : undefined}
			transition:name="hero-scene-bg"
		/>
	)}
	<div class="hero-scene__veil" aria-hidden="true" />

	<div class="hero-scene__copy">
		{eyebrow && <p class="hero-scene__eyebrow" transition:animate={fade({ duration: '320ms' })}>{eyebrow}</p>}
		<h1 class="hero-scene__title" transition:animate={fade({ duration: '420ms' })}>{title}</h1>
		{subtitle && <p class="hero-scene__subtitle" transition:animate={fade({ duration: '320ms' })}>{subtitle}</p>}
		<slot name="actions" />
	</div>
</section>

<style>
	.hero-scene {
		position: relative;
		display: flex;
		align-items: flex-end;
		min-height: 360px;
		padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
		margin-bottom: var(--space-xl);
		background: var(--color-hero-bg);
		color: var(--color-hero-text);
		overflow: hidden;
		isolation: isolate;
		/* Pull full-bleed out of the .main container's max-width. */
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		width: 100vw;
	}
	.hero-scene--tall {
		min-height: 480px;
	}

	/* Background photographic layer (when bgImage present) */
	.hero-scene__bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		opacity: 0.55;
		z-index: 0;
		filter: saturate(0.95) contrast(1.05);
		will-change: transform;
	}

	/* Always-on tonal veil: deeper at the bottom, fades up. Gives the
	   "looking out from inside a scene" feel. */
	.hero-scene__veil {
		position: absolute;
		inset: 0;
		z-index: 1;
		background:
			radial-gradient(120% 80% at 50% 100%, rgba(11,18,32,0.0) 0%, rgba(11,18,32,0.7) 70%, rgba(11,18,32,0.95) 100%),
			linear-gradient(180deg, rgba(11,18,32,0.35) 0%, rgba(11,18,32,0.15) 35%, rgba(11,18,32,0.85) 100%);
	}
	.hero-scene--imageless .hero-scene__veil {
		background:
			radial-gradient(80% 60% at 50% 0%, rgba(180, 83, 9, 0.18), transparent 60%),
			radial-gradient(60% 60% at 80% 100%, rgba(15,118,110,0.18), transparent 60%),
			linear-gradient(180deg, #0b1220 0%, #060a14 100%);
	}

	.hero-scene__copy {
		position: relative;
		z-index: 2;
		max-width: var(--max-width);
		width: 100%;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.hero-scene__eyebrow {
		margin: 0;
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-accent-on-dark);
	}

	.hero-scene__title {
		margin: 0;
		font-size: var(--fs-3xl);
		font-weight: 700;
		line-height: var(--lh-tight);
		letter-spacing: -0.01em;
		color: var(--color-hero-text);
		text-shadow: 0 2px 16px rgba(0,0,0,0.45);
	}

	.hero-scene__subtitle {
		margin: 0;
		max-width: 48rem;
		font-size: var(--fs-md);
		line-height: var(--lh-snug);
		color: var(--color-hero-muted);
	}

	@media (max-width: 640px) {
		.hero-scene {
			min-height: 280px;
			padding: var(--space-2xl) var(--space-md) var(--space-lg);
		}
		.hero-scene--tall { min-height: 360px; }
		.hero-scene__title { font-size: var(--fs-2xl); }
	}
</style>
