---
/**
 * StatStrip — horizontal "by the numbers" lockup.
 *
 * Each stat renders as a large Geist Mono numeric value (with an
 * optional static suffix like "%") above an uppercase Geist Mono
 * label. Stats are hairline-separated.
 *
 * When the strip enters the viewport, the numeric portion of each
 * value counts up from 0 to its target over ~1.5s linear via
 * `IntersectionObserver` + `requestAnimationFrame`. The animation is
 * a progressive enhancement: the SSR'd HTML already contains the
 * final values as text content, so if JS doesn't run (or the user
 * has `prefers-reduced-motion: reduce`) the numbers are still
 * correct and there is no flash of "0".
 *
 * Stats with non-numeric values (e.g., a string like "n/a") fall
 * through the count loop and render their value as-is.
 */

interface Stat {
	/** The displayed value. Numeric values get the count-up; strings render as-is. */
	value: number | string;
	/** Static suffix appended after the numeric portion (e.g., '%', '+'). Not animated. */
	suffix?: string;
	/** Required short label rendered uppercase below the value. */
	label: string;
	/** Optional sub-label (smaller, muted) for additional context. */
	sublabel?: string;
}

interface Props {
	stats: Stat[];
	/** Optional kicker label rendered above the strip. */
	eyebrow?: string;
}

const { stats, eyebrow } = Astro.props;
---

<section class="stat-strip" aria-label={eyebrow ?? 'By the numbers'}>
	{eyebrow && <span class="stat-strip__eyebrow mono">{eyebrow}</span>}
	<dl class="stat-strip__list" data-stat-strip>
		{stats.map((stat) => (
			<div class="stat-strip__item">
				<dt class="stat-strip__value mono">
					<span
						class="stat-strip__num"
						data-stat-target={typeof stat.value === 'number' ? stat.value : ''}
					>{stat.value}</span>
					{stat.suffix && <span class="stat-strip__suffix">{stat.suffix}</span>}
				</dt>
				<dd class="stat-strip__label">
					<span class="stat-strip__label-main">{stat.label}</span>
					{stat.sublabel && <span class="stat-strip__sublabel">{stat.sublabel}</span>}
				</dd>
			</div>
		))}
	</dl>
</section>

<style>
	.stat-strip {
		margin: var(--space-2xl) 0;
	}
	.stat-strip__eyebrow {
		display: block;
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text-subtle);
		margin-bottom: var(--space-md);
	}

	.stat-strip__list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.stat-strip__item {
		padding: var(--space-lg) var(--space-md);
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		border-right: 1px solid var(--color-border);
	}
	.stat-strip__item:last-child { border-right: none; }
	@media (max-width: 640px) {
		.stat-strip__item {
			border-right: none;
			border-bottom: 1px solid var(--color-border);
			padding: var(--space-md) 0;
		}
		.stat-strip__item:last-child { border-bottom: none; }
	}

	.stat-strip__value {
		margin: 0;
		font-size: var(--fs-3xl);
		font-weight: 600;
		line-height: 1;
		color: var(--color-text);
		font-feature-settings: "tnum" on, "ss03" on;
		letter-spacing: -0.02em;
	}
	.stat-strip__suffix {
		font-size: 0.6em;
		font-weight: 500;
		color: var(--color-text-subtle);
		margin-left: 0.05em;
		letter-spacing: 0;
	}

	.stat-strip__label {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.stat-strip__label-main {
		font-family: var(--font-mono);
		font-size: var(--fs-2xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text);
	}
	.stat-strip__sublabel {
		font-size: var(--fs-2xs);
		color: var(--color-text-subtle);
		line-height: var(--lh-snug);
	}
</style>

<script>
	/**
	 * Count-up runner. One observer instance handles every <StatStrip />
	 * on the page. Each strip animates only once. Linear interpolation,
	 * `requestAnimationFrame`-driven, ~1500ms total. Numeric targets
	 * come from the `data-stat-target` attribute on each `.stat-strip__num`;
	 * the SSR'd text content already holds the final value, so if JS
	 * never runs or `prefers-reduced-motion: reduce` is set we leave the
	 * values exactly as the server rendered them.
	 */
	function bindStatStrips() {
		const strips = document.querySelectorAll<HTMLElement>('[data-stat-strip]');
		if (strips.length === 0) return;

		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (reducedMotion) return;

		const DURATION_MS = 1500;

		const animate = (strip: HTMLElement) => {
			// Guard against double-binding: the same script also runs on
			// `astro:page-load`, and IntersectionObserver fires on initial
			// observation of already-visible elements. Without this flag,
			// the second pass would capture the already-reset "0" as the
			// final text and leave values stuck at 0.
			if (strip.dataset.statBound === '1') return;
			strip.dataset.statBound = '1';

			const nums = strip.querySelectorAll<HTMLElement>('.stat-strip__num[data-stat-target]');
			const start = performance.now();

			// Cache final-value strings so the SSR'd content is restored
			// exactly at the end of the animation (preserves any thousands
			// separators we add later).
			const targets: { el: HTMLElement; target: number; finalText: string }[] = [];
			nums.forEach((el) => {
				const t = Number(el.getAttribute('data-stat-target'));
				if (!Number.isFinite(t)) return;
				targets.push({ el, target: t, finalText: el.textContent ?? String(t) });
			});
			if (targets.length === 0) return;

			const tick = (now: number) => {
				const elapsed = now - start;
				const p = Math.min(1, elapsed / DURATION_MS);
				targets.forEach(({ el, target, finalText }) => {
					if (p >= 1) {
						el.textContent = finalText;
					} else {
						el.textContent = String(Math.floor(p * target));
					}
				});
				if (p < 1) requestAnimationFrame(tick);
			};

			// Reset to 0 right before the first frame to avoid a single-
			// frame flash where the SSR'd final value renders, then snaps
			// back to 0, then animates up. By batching the reset and the
			// first tick into the same frame we never render a value
			// mid-state.
			targets.forEach(({ el }) => { el.textContent = '0'; });
			requestAnimationFrame(tick);
		};

		const obs = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					animate(entry.target as HTMLElement);
					obs.unobserve(entry.target);
				}
			});
		}, { threshold: 0.4 });

		strips.forEach((s) => obs.observe(s));
	}

	bindStatStrips();
	document.addEventListener('astro:page-load', bindStatStrips);
</script>
