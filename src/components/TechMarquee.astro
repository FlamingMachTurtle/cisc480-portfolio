---
/**
 * TechMarquee — infinite-scroll horizontal lockup of the tech stack
 * used across projects. Inspired by the user's "Amine" reference site
 * and react-bits' Logo Loop component. CSS-only (no React, no JS),
 * pause-on-hover, prefers-reduced-motion stops it.
 *
 * The list is duplicated once in the markup and animated by
 * `translateX(-50%)` so the loop seam is invisible. Speed is set
 * via the --duration CSS variable on the wrapper.
 *
 * Contents render as Geist Mono small-caps tags separated by middle
 * dots — same convention as the home Skills definition list, so
 * the marquee reads as a continuous extension of that voice rather
 * than a third visual style.
 */
interface Props {
	items?: string[];
	/** Seconds per full loop. Lower = faster. Default 40s. */
	duration?: number;
	label?: string;
}

const {
	items = [
		'TypeScript', 'React', 'Astro', 'Next.js', 'Node.js',
		'Python', 'Java', 'Swift / SwiftUI', 'SQL',
		'Supabase / Postgres', 'eBay Trading API', 'QuickBooks Online',
		'Google Sheets API', 'Power BI / DAX', 'GSAP', 'Framer Motion',
		'Vercel', 'Git / GitHub Actions',
	],
	duration = 50,
	label = 'Stack in rotation',
} = Astro.props;
---

<section class="marquee-section" aria-label={label}>
	<div class="marquee-head">
		<span class="marquee-label">{label}</span>
		<span class="marquee-hint">Hover to pause</span>
	</div>

	<div class="marquee" style={`--duration: ${duration}s`}>
		<div class="marquee__track" aria-hidden="false">
			<ul class="marquee__row">
				{items.map((it) => <li>{it}</li>)}
			</ul>
			{/* Duplicate the row once so the translateX(-50%) loop
			    seam is invisible. The duplicate is hidden from
			    assistive tech to avoid double announcements. */}
			<ul class="marquee__row" aria-hidden="true">
				{items.map((it) => <li>{it}</li>)}
			</ul>
		</div>
	</div>
</section>

<style>
	.marquee-section {
		margin: var(--space-3xl) 0;
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}

	.marquee-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-sm);
		margin-bottom: var(--space-md);
		flex-wrap: wrap;
	}
	.marquee-label {
		font-size: var(--fs-2xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--color-text);
	}
	.marquee-hint {
		font-size: var(--fs-xs);
		color: var(--color-text-subtle);
		font-style: italic;
	}

	/* The viewport — fades-out at both edges so the loop seam is
	   visually masked. The fade is a CSS mask, not a gradient
	   overlay, so it follows the page background regardless of
	   theme. */
	.marquee {
		position: relative;
		overflow: hidden;
		mask-image: linear-gradient(
			to right,
			transparent 0,
			black 8%,
			black 92%,
			transparent 100%
		);
		-webkit-mask-image: linear-gradient(
			to right,
			transparent 0,
			black 8%,
			black 92%,
			transparent 100%
		);
	}

	.marquee__track {
		display: flex;
		gap: 0;
		width: max-content;
		animation: marquee-scroll var(--duration, 50s) linear infinite;
	}
	.marquee:hover .marquee__track,
	.marquee:focus-within .marquee__track {
		animation-play-state: paused;
	}

	.marquee__row {
		display: flex;
		gap: var(--space-xl);
		list-style: none;
		margin: 0;
		padding: 0 var(--space-lg);
		flex-shrink: 0;
	}

	.marquee__row li {
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
		font-weight: 500;
		color: var(--color-text-muted);
		white-space: nowrap;
		font-feature-settings: "tnum" on, "ss01" on, "ss03" on;
		display: flex;
		align-items: center;
		transition: color 0.2s ease;
	}
	.marquee__row li:not(:last-child)::after {
		content: '';
		display: inline-block;
		width: 4px;
		height: 4px;
		margin-left: var(--space-xl);
		margin-right: calc(-1 * var(--space-xl));
		border-radius: 50%;
		background: var(--color-border-strong);
		flex-shrink: 0;
	}
	.marquee__row li:hover {
		color: var(--color-text);
	}

	@keyframes marquee-scroll {
		from { transform: translateX(0); }
		to   { transform: translateX(-50%); }
	}

	@media (prefers-reduced-motion: reduce) {
		.marquee__track {
			animation: none;
			transform: translateX(0);
		}
		.marquee {
			mask-image: none;
			-webkit-mask-image: none;
			overflow-x: auto;
			scrollbar-width: thin;
		}
	}
</style>
