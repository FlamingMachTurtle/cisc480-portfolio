---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { withBase } from '../lib/url';

interface Props {
	title: string;
	description?: string;
	/**
	 * If true, the sticky header starts opaque (used for pages that
	 * don't have a HeroScene at the top). Defaults to false so most
	 * pages render with a transparent header over their dark hero.
	 */
	staticHeader?: boolean;
}

const {
	title,
	description = 'Eli Goldberger — CISC480 Senior Capstone individual portfolio. Computer Science major specializing in practical automation, rapid prototyping, and tools that help small businesses and underserved users.',
	staticHeader = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://flamingmachturtle.github.io');
const pathname = Astro.url.pathname;
const isHome = pathname === withBase('/') || pathname === import.meta.env.BASE_URL;
const startsWithBase = (segment: string) => pathname.startsWith(withBase(segment));
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="icon" href={withBase('/favicon.ico')} sizes="any" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Eli Goldberger — CISC480 Portfolio</title>
		<link rel="canonical" href={canonicalURL.href} />
		<meta property="og:title" content={`${title} | Eli Goldberger — CISC480 Portfolio`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<ClientRouter />
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<header class:list={['site-header', { 'is-static': staticHeader }]} role="banner" data-static-header={staticHeader ? 'true' : 'false'}>
			<nav class="nav" aria-label="Main">
				<a href={withBase('/')} class="nav-home">Eli Goldberger</a>
				<ul class="nav-links">
					<li><a href={withBase('/')} class={isHome ? 'active' : ''}>Home</a></li>
					<li><a href={withBase('/projects/')} class={startsWithBase('/projects') ? 'active' : ''}>Projects</a></li>
					<li><a href={withBase('/resume/')} class={startsWithBase('/resume') ? 'active' : ''}>Resume</a></li>
					<li><a href={withBase('/fun/')} class={startsWithBase('/fun') ? 'active' : ''}>Fun Stuff</a></li>
				</ul>
			</nav>
		</header>
		<main id="main-content" class="main" tabindex="-1">
			<slot />
		</main>
		<footer class="site-footer" role="contentinfo">
			<p class="footer-contact">
				<a href="mailto:eligoldberger5@gmail.com">eligoldberger5@gmail.com</a>
				<span aria-hidden="true"> · </span>
				<a href="https://www.linkedin.com/in/eli-goldberger-b3b440212/" target="_blank" rel="noopener">LinkedIn</a>
				<span aria-hidden="true"> · </span>
				<a href="https://github.com/FlamingMachTurtle" target="_blank" rel="noopener">GitHub</a>
			</p>
			<p class="footer-copy">© {new Date().getFullYear()} Eli Goldberger · CISC480 Senior Capstone, Spring 2026</p>
		</footer>

		{/*
		 * GSAP scene layer (body lift + hero parallax) — bundled by
		 * Astro, runs on every astro:page-load. See
		 * redesign/animation-options.md for the recipe.
		 */}
		<script>
			import '../scripts/scene';
		</script>

		{/*
		 * Sticky-header opacity controller + dynamic header-overlap.
		 *
		 * (1) Toggles `.is-scrolled` once the user has scrolled past
		 *     the top hero band (or 80px if no hero is present).
		 * (2) Measures the actual header height and writes it to a
		 *     `--header-overlap` CSS custom property on every .main.
		 *     This is what lets the leading `<HeroScene>` pull itself
		 *     up *exactly* under the sticky header — no white sliver
		 *     gap, regardless of font load state (Geist Variable
		 *     swaps after first paint and the line metrics shift
		 *     ~1–2px), nav-wrap on mobile (the nav uses
		 *     flex-wrap: wrap and grows ~2x tall when links wrap),
		 *     viewport resize, or user zoom. CSS provides a safe
		 *     4.25rem fallback (see .main rule in global.css) so the
		 *     band is gap-free even before this script runs.
		 *
		 * Re-bound on every astro:page-load so view transitions don't
		 * leak listeners.
		 */}
		<script is:inline>
			(function () {
				let cleanup = null;

				function writeHeaderOverlap(header) {
					/* Round up + small buffer so sub-pixel line-height
					   doesn't leave a 1px sliver. */
					const px = Math.ceil(header.getBoundingClientRect().height) + 2;
					const mains = document.querySelectorAll('.main');
					mains.forEach((m) => {
						m.style.setProperty('--header-overlap', px + 'px');
					});
				}

				function bind() {
					if (cleanup) cleanup();
					const header = document.querySelector('.site-header');
					if (!header) return;

					writeHeaderOverlap(header);
					const isStatic = header.dataset.staticHeader === 'true';

					/* Re-measure on events that can change header
					   height: font swap (Geist Variable), viewport
					   resize, orientation change. */
					const remeasure = () => writeHeaderOverlap(header);
					window.addEventListener('resize', remeasure, { passive: true });
					if (document.fonts && document.fonts.ready) {
						document.fonts.ready.then(() => writeHeaderOverlap(header));
					}

					/* Static-header pages don't need the scroll toggle. */
					if (isStatic) {
						cleanup = () => window.removeEventListener('resize', remeasure);
						return;
					}

					const hero = document.querySelector('.hero-scene');
					const threshold = hero
						? hero.getBoundingClientRect().bottom + window.scrollY - header.offsetHeight - 24
						: 80;

					const onScroll = () => {
						if (window.scrollY >= threshold) header.classList.add('is-scrolled');
						else header.classList.remove('is-scrolled');
					};
					onScroll();
					window.addEventListener('scroll', onScroll, { passive: true });
					cleanup = () => {
						window.removeEventListener('scroll', onScroll);
						window.removeEventListener('resize', remeasure);
					};
				}

				document.addEventListener('astro:page-load', bind);
				if (document.readyState !== 'loading') bind();
				else document.addEventListener('DOMContentLoaded', bind);
			})();
		</script>
	</body>
</html>
